import queue
import threading

def worker(q):
    """
    Worker thread function: continuously gets tasks from the queue.
    Exits when queue.Empty exception is raised (timeout reached).
    
    Args:
        q: Queue object containing tasks to process
    """
    while True:
        try:
            # Get task with timeout (prevents infinite blocking)
            name = q.get(timeout=1)
        except queue.Empty:
            break  # No more tasks, exit thread
        print(name)
        q.task_done()  # Mark task as completed

def spawn_name_with_pooling_queueing():
    """
    Main function for Activity 1:
    - Gets user name and repetition count
    - Creates a queue with 'Hello [name]!' messages
    - Spawns 3 worker threads to process the queue
    """
    name = input("What's your name? ")
    times = int(input("How many times should your name be spawned? "))

    # Create a queue and populate with tasks
    q = queue.Queue()
    for _ in range(times):
        q.put("Hello " + name + "!")

    # Create and start worker threads (thread pool of size 3)
    num_workers = 3
    threads = []
    for _ in range(num_workers):
        t = threading.Thread(target=worker, args=(q,))
        t.start()
        threads.append(t)

    # Wait for all tasks in queue to be processed
    q.join()

    # Wait for all threads to complete
    for t in threads:
        t.join()

# Run Activity 1
