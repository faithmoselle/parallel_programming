import multiprocessing
import time
import random

def digger_worker(name, hole_number, lock, turn, my_index):
    """
    Worker process function:
    - Simulates work with random sleep
    - Uses lock and turn value to print in sequential order
    
    Args:
        name: Worker name (A, B, C, ...)
        hole_number: Assigned hole (0-9)
        lock: Multiprocessing Lock for synchronization
        turn: Shared value indicating which process should print next
        my_index: This process's turn index (0-9)
    """
    # Simulate variable work time (digging)
    time.sleep(random.uniform(0.1, 1))
    
    # Wait until it's this process's turn to print
    while True:
        with lock:  # Ensure exclusive access to turn variable
            if turn.value == my_index:
                print(f"Hey how you doin'! I'm worker {name}, and today I will be digging hole {hole_number}")
                turn.value += 1  # Pass turn to next worker
                break
        time.sleep(0.01)  # Small delay to prevent busy-waiting

def assignDiggers():
    """
    Main function for Activity 2:
    - Creates 10 digger processes (A through J)
    - Each assigned a hole (0 through 9)
    - Uses lock and turn to control print order
    """
    digger_names = ["A", "B", "C", "D", "E", "F", "G", "H", "I", "J"]
    holes = list(range(10))
    
    # Shared synchronization primitives
    lock = multiprocessing.Lock()
    turn = multiprocessing.Value('i', 0)  # Shared integer starting at 0
    
    processes = []
    
    # Create and start process for each digger
    for i, name in enumerate(digger_names):
        assigned_hole = holes[i]
        p = multiprocessing.Process(
            target=digger_worker, 
            args=(name, assigned_hole, lock, turn, i)
        )
        processes.append(p)
        p.start()
    
    # Wait for all processes to complete
    for p in processes:
        p.join()

if __name__ == "__main__":
    assignDiggers()

