from multiprocessing import Process, Semaphore
import time
import random


def cookOrder(customerID, restaurant, semaphore):
    """
    Simulate a chef cooking a customer's order.
    
    This function represents a chef preparing food for a specific customer.
    It uses a semaphore to ensure only 3 chefs work at the same time.
    
    Args:
        customerID: The customer's order number
        restaurant: Name of the restaurant (for display)
        semaphore: Semaphore controlling access to limited chefs (max 3)
    
    Process Flow:
    1. Acquire semaphore (wait for an available chef)
    2. Simulate cooking time (random 1-5 seconds)
    3. Release semaphore (chef becomes available again)
    """
    # Acquire a chef (blocks if all 3 are busy)
    semaphore.acquire()
    
    try:
        # Print message when cooking starts
        print(f"A chef has now started preparing order for Customer {customerID}")
        
        # Simulate cooking time (random between 1 and 5 seconds)
        cooking_time = random.randint(1, 5)
        time.sleep(cooking_time)
        
        # Print message when order is complete
        print(f"Order for Customer {customerID} is ready for pickup. \n")
        
    finally:
        # Always release the semaphore (ensures chef availability)
        semaphore.release()


def processOrders():
    """
    Main function to process customer orders in a restaurant.
    
    Steps:
    1. Get restaurant name from user
    2. Get number of customers from user (with input validation)
    3. Create a semaphore with 3 permits (simulating 3 chefs)
    4. Create and start a process for each customer
    5. Wait for all processes to complete
    6. Display completion message
    """
    
    # 1. Get restaurant name from user
    restaurant_name = input("Restaurant: ")
    
    # 2. Get number of customers (with validation)
    try:
        num_customers = int(input("How many customers are placing their orders today? "))
        if num_customers <= 0:
            print("Great!")  # Handles 0 or negative inputs gracefully
            return
    except ValueError:
        # Handle non-integer input
        print("We only accept integers.")
        return
    
    # 3. Create semaphore with 3 permits (simulating 3 chefs)
    # Only 3 chefs can cook simultaneously
    chef_semaphore = Semaphore(3)
    
    # List to keep track of all processes
    processes = []
    
    print(f"In {restaurant_name} we dine!")
    print(f"The {num_customers} customer/s has now placed their orders!")
    print("Our 3 chefs are cooking their order!")
    print("========")
    
    # 4. Create and start a process for each customer
    for customer_id in range(1, num_customers + 1):
        process = Process(
            target=cookOrder,
            args=(customer_id, restaurant_name, chef_semaphore)
        )
        processes.append(process)
        process.start()
    
    # 5. Wait for all processes to complete
    for process in processes:
        process.join()
    
    # 6. Display completion message
    print("========")
    print(f"The {restaurant_name} has now served all order/s. Thank you for your support!")


# Standard Python idiom: only run main when script is executed directly
if __name__ == "__main__":
    processOrders()
