# ============================================================================
# ACTIVITY 2: Queue-Based Square Calculator
# ============================================================================
print("\n" + "=" * 60)
print("ACTIVITY 2: Queue-based Square Calculator")
print("=" * 60)

def square_worker(number, queue):
    """Compute square and send result through queue."""
    square = number ** 2
    queue.put((number, square))

if __name__ == "__main__":
    numbers = [12, 60, 45, 14]
    queue = Queue()
    processes = []
    
    # Create one process per number
    for num in numbers:
        process = Process(target=square_worker, args=(num, queue))
        processes.append(process)
        process.start()
    
    # Collect results from queue
    results = []
    for _ in numbers:
        results.append(queue.get())
    
    # Wait for all processes
    for process in processes:
        process.join()
    
    print("Results using multiprocessing.Queue:")
    for original, squared in results:
        print(f"  {original} squared is {squared}")

