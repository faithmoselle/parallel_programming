print("ACTIVITY 1: User Input - Parallel Square Computation")
print("=" * 60)

def calculate_square_with_number(n):
    """Return tuple of (number, square) for display."""
    return n, n ** 2

if __name__ == "__main__":
    # Get 3 integers from user
    user_numbers = []
    for i in range(3):
        num = int(input(f"Enter integer {i+1}: "))
        user_numbers.append(num)
    
    # Compute squares in parallel
    with Pool() as pool:
